function update_terminal_title() { print -Pn "\e]0;%n :: %~/ \a" }

# The next line updates PATH for the Google Cloud SDK.
if [ -f '/home/jf/.google-cloud-sdk/path.zsh.inc' ]; then source '/home/jf/.google-cloud-sdk/path.zsh.inc'; fi
if [ -f '/Users/jf/.google-cloud-sdk/path.zsh.inc' ]; then source '/Users/jf/.google-cloud-sdk/path.zsh.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/home/jf/.google-cloud-sdk/completion.zsh.inc' ]; then source '/home/jf/.google-cloud-sdk/completion.zsh.inc'; fi
if [ -f '/Users/jf/.google-cloud-sdk/completion.zsh.inc' ]; then source '/Users/jf/.google-cloud-sdk/completion.zsh.inc'; fi

# if [ $commands[kubectl] ]; then
#   source <(kubectl completion zsh)
# fi

# direnv
if [ $commands[direnv] ]; then
  eval "$(direnv hook zsh)";

  if [ -n "$TMUX" ] && [ -n "$DIRENV_DIR" ]; then
    direnv reload
  fi
fi

# mise
if [ $commands[mise] ]; then
  eval "$(mise activate zsh)"
fi
